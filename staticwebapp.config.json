{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*.{png,jpg,jpeg,gif,svg,webp,ico}",
      "/styles.css",
      "/main.js"
    ]
  },
  "mimeTypes": {
    ".svg": "image/svg+xml"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
